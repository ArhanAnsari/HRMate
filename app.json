{
  "expo": {
    "name": "HRMate",
    "slug": "hrmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/images/icon.png",
    "scheme": "hrmate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "assets/images/hrmate-app-assets/android/splash/android-splash-1920x1920.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "assets/images/hrmate-app-assets/android/splash/android-splash-1920x1920.png",
        "backgroundColor": "#0F172A"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hrmate.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "assets/images/android-icon-foreground.png",
        "backgroundImage": "assets/images/android-icon-background.png",
        "monochromeImage": "assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.hrmate.app"
    },
    "web": {
      "output": "static",
      "favicon": "assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "assets/images/hrmate-app-assets/android/splash/android-splash-1920x1920.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#0F172A"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow HRMate to use Face ID for secure login"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "assets/images/icon.png",
          "color": "#2563EB"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
