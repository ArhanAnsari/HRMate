{
  "expo": {
    "name": "HRMate",
    "slug": "hrmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/images/icon.png",
    "scheme": "hrmate",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "assets/images/hrmate-app-assets/android/splash/android-splash-1920x1920.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "assets/images/hrmate-app-assets/android/splash/android-splash-1920x1920.png",
        "backgroundColor": "#0F172A"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arhanansari.HRMate"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "assets/images/android-icon-foreground.png",
        "backgroundImage": "assets/images/android-icon-background.png",
        "monochromeImage": "assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.arhanansari.HRMate",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "assets/images/hrmate-app-assets/android/splash/android-splash-1920x1920.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#0F172A"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow HRMate to use Face ID for secure login"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "assets/images/icon.png",
          "color": "#2563EB"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "hrmate",
          "organization": "arhanansari"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "21342faf-9dd2-4030-9da8-c83a6e438b7f"
      }
    }
  }
}
